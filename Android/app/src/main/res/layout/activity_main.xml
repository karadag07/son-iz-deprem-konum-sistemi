<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020617">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Son İz"
            android:textColor="#F8FAFC"
            android:textSize="40sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="15dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Afet öncesi son konum kayıt sistemi"
            android:textColor="#94A3B8"
            android:gravity="center"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtTrackingInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="#0F172A"
            android:elevation="6dp"
            android:padding="18dp"
            android:text="Otomatik gönderim: Kapalı"
            android:textColor="#38BDF8"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#061E29"
            android:elevation="10dp"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Durum: Hazır"
                android:textColor="#22C55E"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Konum: Henüz alınmadı"
                android:textColor="#CBD5E1"
                android:textSize="16sp" />

        </LinearLayout>

        <Button
            android:id="@+id/btnGetLocation"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="#1E293B"
            android:text="Anlık Konumu Al"
            android:textColor="#E2E8F0"
            android:textSize="16sp"
            android:textStyle="bold"
            android:elevation="6dp" />

        <Button
            android:id="@+id/btnStartTracking"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="#0F766E"
            android:text="30 Saniyede Bir Gönderimi Başlat"
            android:textColor="#CCFBF1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:elevation="6dp" />

        <Button
            android:id="@+id/btnStopTracking"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="#7F1D1D"
            android:text="Gönderimi Durdur"
            android:textColor="#FECACA"
            android:textSize="15sp"
            android:textStyle="bold"
            android:elevation="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="#0F172A"
            android:elevation="6dp"
            android:padding="18dp"
            android:text="Demo modunda konum 30 saniyede bir gönderilir. Gerçek sistemde bu süre 30 dakika olarak ayarlanacaktır."
            android:textColor="#CBD5E1"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>