PORT=4000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=change-this-secret

# Konum veri kaynağı.
# app.zip içindeki Spring Boot projesi PostgreSQL'e şu ayarlarla bağlanıyor:
# jdbc:postgresql://localhost:5432/postgres
DATA_SOURCE=postgres
PGHOST=localhost
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=1
PGSSL=false
LOCATION_TABLE=device_locations
MAX_LOCATION_ROWS=50000

# app.zip tablosunda accuracy/network alanı yoksa panel varsayılan doğruluk kullanır.
DEFAULT_LOCATION_ACCURACY_METERS=50

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
